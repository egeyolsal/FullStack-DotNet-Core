@model basics.Models.Course

<div class="card mb-3" id="course-@Model.Id"> 
    <div class="row">
        <div class="col-md-4">
            <img src="/img/@Model.Image" class="img-fluid rounded start" alt="Course Image" />  
        </div>
        
        <div class="col-md-8">
            <div class="card-body"> 
                <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id">
                    <h5 class="card-title">@Model.Title</h5>
                </a>  
                <p class="card-text">@Model.description</p>
            </div>
        </div>
    </div>  
</div>